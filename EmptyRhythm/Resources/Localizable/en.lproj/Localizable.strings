/* AI */
"ai.disclaimer" = "AI content is for reference only. Not medical advice. Consult your doctor for health concerns.";
"ai.welcome" = "Hi! I'm your fasting assistant. Ask me anything about intermittent fasting, nutrition, or your health goals.";
"ai.input.placeholder" = "Ask me anything...";
"quick.q1" = "What can I drink while fasting?";
"quick.q2" = "I feel dizzy, what should I do?";
"quick.q3" = "What's the best plan for me?";
"quick.q4" = "How many calories should I eat?";
"quick.q5" = "Tips for beginners";
"quick.q6" = "Can I exercise while fasting?";
"ai.response.drinks" = "During fasting, you can drink: water, black coffee (no sugar/milk), plain tea, sparkling water. Avoid: juice, milk, soda, or anything with calories that breaks your fast.";
"ai.response.dizzy" = "Dizziness during fasting is common, especially in the first week. Try: drink more water, add a pinch of salt, take electrolytes, or break your fast if symptoms persist. If severe, please consult a doctor.";
"ai.response.hunger" = "Hunger during fasting is normal. Tips: drink water or black coffee, stay busy, remind yourself hunger waves pass in 20 minutes. If unbearable, it's okay to break your fast and try again tomorrow.";
"ai.response.plan" = "Based on your profile, I recommend the %@ plan (%d hours fasting, %d hours eating). This is tailored to your BMI and health status.";
"ai.response.plan_no_profile" = "Please complete your health profile first so I can recommend a personalized fasting plan.";
"ai.response.calorie" = "Based on your profile, your daily calorie target is %d kcal with a %d kcal deficit for weight loss.";
"ai.response.calorie_no_profile" = "Please complete your health profile to get personalized calorie recommendations.";
"ai.response.weight" = "Weight loss during fasting: expect 0.5-1 kg/week with consistent fasting + calorie control. First week may show more loss due to water weight. Focus on weekly averages, not daily fluctuations.";
"ai.response.exercise" = "Light to moderate exercise is fine during fasting. Best timing: end of fasting period or during eating window. Avoid intense workouts during extended fasts. Stay hydrated!";
"ai.response.period" = "During menstruation, consider reducing fasting intensity (12:12 or 14:10). Prioritize nutrition and rest. Some women prefer not to fast during their period - listen to your body.";
"ai.response.beginner" = "Start with 12:12 (fast 12h, eat 12h) for 1-2 weeks. Then progress to 14:10, then 16:8. Don't rush - building the habit is more important than intensity. Drink plenty of water!";
"ai.response.default" = "That's a great question about fasting! The key principles are: stay hydrated, break your fast gently, listen to your body, and be consistent. Would you like more specific advice? Try asking about drinks, hunger, exercise, or your personalized plan.";

